# ──────────────────────────────────────────────────────────────────────────────
# panw-api-ollama — Docker environment template
# Copy to .env and fill in the required values before running docker compose.
#
#   cp .env.example .env
#
# ──────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────────────────
# Palo Alto Networks AI Runtime Security credentials.
# Obtain from https://aisecurity.paloaltonetworks.com
SECURITY_API_KEY=
SECURITY_PROFILE_NAME=

# ── SECURITY (optional) ───────────────────────────────────────────────────────
SECURITY_BASE_URL=https://service.api.aisecurity.paloaltonetworks.com
SECURITY_APP_NAME=panw-api-ollama
SECURITY_APP_USER=docker

# Multi-line grounding context sent to PANW with every response scan.
# Leave empty to disable grounding checks.
SECURITY_CONTEXTUAL_GROUNDING_CONTEXT=

# ── SERVER (optional) ─────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=11435
SERVER_DEBUG_LEVEL=INFO
RUST_LOG=info

# ── OLLAMA (optional) ─────────────────────────────────────────────────────────
# Internal Docker network address — do not change unless you move the ollama
# service or use an external Ollama instance.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_DOCKER_TAG=latest

# ── OPEN WEBUI (optional) ─────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 32
WEBUI_SECRET_KEY=
# Pin to a specific version tag (e.g. v0.9.5) or leave as default.
WEBUI_DOCKER_TAG=v0.9.5
# Host port exposed for the Open WebUI interface.
OPEN_WEBUI_PORT=3000
ENABLE_OPENAI_API=false
